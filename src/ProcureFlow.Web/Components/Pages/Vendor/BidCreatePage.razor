@page "/vendor/bids/create/{RfpId:int}"
@using ProcureFlow.Web.Components.Shared
@using ProcureFlow.Web.Endpoints.Vendor
@using ProcureFlow.Core.Entities
@inject VendorApiClient VendorApi
@inject NavigationManager Navigation

<PageHeader Title="Create Bid" Subtitle="Respond with your pricing and details" />

@if (IsLoading)
{
    <div class="card">
        <div class="card-header">Loading RFP</div>
        <p style="margin: 1rem 0 0 0; color: var(--gray-700);">Fetching vendor-safe RFP detail...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="card" style="border: 1px solid var(--danger-color);">
        <div class="card-header">Unable to prepare bid</div>
        <p style="margin: 1rem 0; color: var(--danger-color);">@ErrorMessage</p>
        <div style="display: flex; gap: 0.75rem;">
            <button type="button" class="btn btn-secondary" @onclick="LoadAsync">Retry</button>
            <a href="@InvitesHref" class="btn btn-secondary">Back to Invites</a>
        </div>
    </div>
}
else if (Rfp is not null && Rfp.ExistingBidId.HasValue)
{
    <div class="card" style="max-width: 860px;">
        <div class="card-header">Bid Already Exists</div>
        <p style="margin: 1rem 0; color: var(--gray-700);">A bid already exists for this invite. Open the existing bid to continue editing instead of creating a duplicate response.</p>
        <div style="display: flex; gap: 0.75rem;">
            <a href="@($"/vendor/bids/{Rfp.ExistingBidId.Value}/edit?companyId={CompanyId}")" class="btn btn-primary">Open Existing Bid</a>
            <a href="@InvitesHref" class="btn btn-secondary">Back to Invites</a>
        </div>
    </div>
}
else if (Rfp is not null)
{
    <div class="card" style="max-width: 960px;">
        <div class="card-header">RFP Items and Your Bid Response</div>

        <div class="grid grid-3" style="margin-top: 1rem; align-items: end;">
            <div class="form-group">
                <label class="form-label">Vendor Company Id</label>
                <input type="number" class="form-control" @bind="CompanyIdInput" />
            </div>
            <div class="form-group">
                <label class="form-label">Currency</label>
                <input type="text" class="form-control" @bind="Currency" />
            </div>
            <div class="form-group">
                <label class="form-label">VAT Rate</label>
                <input type="number" class="form-control" @bind="VatRate" step="0.01" />
            </div>
        </div>

        <div style="margin-top: 1rem; color: var(--gray-700); line-height: 1.6;">
            <strong>Buyer:</strong> @Rfp.BuyerCompanyName<br />
            <strong>RFP:</strong> @Rfp.Title<br />
            <strong>Deadline:</strong> @(Rfp.Deadline?.ToLocalTime().ToString("g") ?? "Open")
        </div>

        <div style="overflow-x: auto; margin-top: 1rem;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background-color: var(--gray-50); border-bottom: 2px solid var(--gray-300);">
                        <th style="text-align: left; padding: 1rem; font-weight: 600;">Item</th>
                        <th style="text-align: center; padding: 1rem; font-weight: 600;">Qty</th>
                        <th style="text-align: left; padding: 1rem; font-weight: 600;">Brand</th>
                        <th style="text-align: left; padding: 1rem; font-weight: 600;">Your Unit Price</th>
                        <th style="text-align: right; padding: 1rem; font-weight: 600;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        <tr style="border-bottom: 1px solid var(--gray-200); vertical-align: top;">
                            <td style="padding: 1rem; min-width: 240px;">
                                <div style="font-weight: 600;">@item.Name</div>
                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <div style="margin-top: 0.25rem; color: var(--gray-700); font-size: 0.85rem;">@item.Note</div>
                                }
                            </td>
                            <td style="text-align: center; padding: 1rem;">@item.Quantity @item.Unit</td>
                            <td style="padding: 1rem; min-width: 160px;">
                                <input type="text" class="form-control" @bind="item.Brand" />
                            </td>
                            <td style="padding: 1rem; min-width: 160px;">
                                <input type="number" class="form-control" @bind="item.UnitPrice" step="0.01" />
                            </td>
                            <td style="text-align: right; padding: 1rem;">@item.TotalPrice.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="margin-top: 1.5rem; background-color: var(--gray-50); padding: 1rem; border-radius: 4px; text-align: right;">
            <p style="margin: 0; font-size: 1.1rem;"><strong>Subtotal:</strong> @SubTotal.ToString("N2")</p>
            <p style="margin: 0.5rem 0 0 0; font-size: 1.1rem;"><strong>Grand Total:</strong> <span style="color: var(--primary-color); font-size: 1.3rem;">@GrandTotal.ToString("N2") @Currency</span></p>
        </div>

        <div class="form-group" style="margin-top: 1.5rem;">
            <label class="form-label">Bid Notes / Terms</label>
            <textarea class="form-control" rows="4" @bind="Proposal"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(InfoMessage))
        {
            <div style="margin-top: 1rem; padding: 1rem; border: 1px solid var(--primary-color); border-radius: 4px; color: var(--primary-color);">@InfoMessage</div>
        }

        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="button" class="btn btn-primary btn-lg" @onclick="HandleSubmit" disabled="@IsSubmitting">@(IsSubmitting ? "Submitting..." : "Submit Bid")</button>
            <a href="@InvitesHref" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </div>
}

@code {
    [Parameter]
    public int RfpId { get; set; }

    [SupplyParameterFromQuery]
    public int? CompanyIdQuery { get; set; }

    private bool IsLoading = true;
    private bool IsSubmitting;
    private string? ErrorMessage;
    private string? InfoMessage;
    private int CompanyId = 1;
    private string CompanyIdInput = "1";
    private string Currency = "VND";
    private decimal VatRate = 10m;
    private string? Proposal;
    private VendorRfpDetailResponse? Rfp;
    private List<BidItemModel> Items = new();

    private string InvitesHref => $"/vendor/invites?companyId={CompanyId}";
    private decimal SubTotal => Items.Sum(item => item.TotalPrice);
    private decimal GrandTotal => SubTotal * (1 + (VatRate / 100m));

    protected override async Task OnInitializedAsync()
    {
        if (CompanyIdQuery is > 0)
        {
            CompanyId = CompanyIdQuery.Value;
            CompanyIdInput = CompanyId.ToString();
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        InfoMessage = null;
        StateHasChanged();

        try
        {
            Rfp = await VendorApi.GetRfpAsync(RfpId, CompanyId);
            Items = Rfp.Items.Select(item => new BidItemModel
            {
                RfpItemId = item.Id,
                Name = item.Name,
                Quantity = item.Quantity,
                Unit = item.Unit,
                Note = item.Note,
                Brand = string.Empty,
                UnitPrice = 0m,
                Specs = item.Specs.Select(spec => new BidSpecModel
                {
                    Key = spec.Key,
                    ValueText = spec.ValueText,
                    ValueNumber = spec.ValueNumber,
                    ValueBoolean = spec.ValueBoolean,
                    Unit = spec.Unit
                }).ToList()
            }).ToList();
        }
        catch (ApiException ex)
        {
            ErrorMessage = ex.Error.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error while loading vendor RFP detail: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (!int.TryParse(CompanyIdInput, out var parsedCompanyId) || parsedCompanyId <= 0)
        {
            ErrorMessage = "Enter a valid vendor company id before submitting a bid.";
            return;
        }

        CompanyId = parsedCompanyId;
        IsSubmitting = true;
        ErrorMessage = null;
        InfoMessage = null;

        try
        {
            var result = await VendorApi.CreateBidAsync(new CreateBidRequest(
                RfpId,
                CompanyId,
                VatRate,
                SubTotal,
                GrandTotal,
                Currency,
                Proposal,
                RfpBidPrivacyMode.Standard,
                Items.Select(item => new CreateBidItemRequest(
                    item.RfpItemId,
                    item.Brand,
                    item.Quantity,
                    item.UnitPrice,
                    item.TotalPrice,
                    item.Note,
                    item.Specs.Select(spec => new CreateBidItemSpecRequest(spec.Key, spec.ValueText, spec.ValueNumber, spec.ValueBoolean, spec.Unit)).ToList()))
                    .ToList()));

            Navigation.NavigateTo($"/vendor/bids/{result.Id}/edit?companyId={CompanyId}");
        }
        catch (ApiException ex)
        {
            ErrorMessage = ex.Error.Code switch
            {
                "BID_ALREADY_EXISTS" when Rfp?.ExistingBidId is not null => "A bid already exists for this RFP. Redirecting to the existing bid is recommended.",
                "NOT_INVITED" => "This vendor company is not invited to the selected RFP.",
                _ => ex.Error.Message
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error while submitting the bid: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private sealed class BidItemModel
    {
        public int RfpItemId { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public string Unit { get; set; } = string.Empty;
        public string? Note { get; set; }
        public string? Brand { get; set; }
        public decimal UnitPrice { get; set; }
        public List<BidSpecModel> Specs { get; set; } = new();
        public decimal TotalPrice => Quantity * UnitPrice;
    }

    private sealed class BidSpecModel
    {
        public string Key { get; set; } = string.Empty;
        public string? ValueText { get; set; }
        public decimal? ValueNumber { get; set; }
        public bool? ValueBoolean { get; set; }
        public string? Unit { get; set; }
    }
}
