@page "/vendor/contracts/{ContractId:int}"
@using ProcureFlow.Web.Components.Shared
@using ProcureFlow.Web.Endpoints.Vendor
@using ProcureFlow.Core.Entities
@inject VendorApiClient VendorApi

<PageHeader Title="Sign Contract" Subtitle="Review finalized terms and provide signature" />

<div class="card" style="margin-bottom: 1.5rem; max-width: 420px;">
    <div class="card-header">Vendor Context</div>
    <div class="form-group" style="margin-top: 1rem;">
        <label class="form-label">Vendor Company Id</label>
        <input type="number" class="form-control" @bind="CompanyIdInput" />
    </div>
    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
        <button type="button" class="btn btn-primary" @onclick="ApplyCompanyAsync" disabled="@IsLoading">Load Contract</button>
        <button type="button" class="btn btn-secondary" @onclick="LoadAsync" disabled="@(IsLoading || CompanyId <= 0)">Refresh</button>
    </div>
</div>

@if (IsLoading)
{
    <div class="card">
        <div class="card-header">Loading contract</div>
        <p style="margin: 1rem 0 0 0; color: var(--gray-700);">Fetching vendor contract detail...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="card" style="border: 1px solid var(--danger-color);">
        <div class="card-header">Contract unavailable</div>
        <p style="margin: 1rem 0; color: var(--danger-color);">@ErrorMessage</p>
        <button type="button" class="btn btn-secondary" @onclick="LoadAsync">Retry</button>
    </div>
}
else if (Contract is not null)
{
    <div class="grid grid-2">
        <div class="card">
            <div class="card-header">Contract Overview</div>
            <p style="margin: 0.5rem 0; color: var(--gray-700); line-height: 1.7;">
                <strong>Contract No:</strong> @Contract.ContractNo<br />
                <strong>RFP Id:</strong> @Contract.RfpId<br />
                <strong>Document:</strong> @Contract.FileUrl
            </p>
        </div>

        <div class="card">
            <div class="card-header">Current Status</div>
            <div style="margin: 1rem 0;">
                <StatusBadge Status="@ToContractStatusLabel(Contract.Status)" />
            </div>
            <p style="margin: 0; color: var(--gray-700); font-size: 0.9rem;">
                @(Contract.BuyerSign ? "Buyer has signed. Vendor action is now available." : "Buyer signature is still pending.")
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(InfoMessage))
    {
        <div class="card" style="border: 1px solid var(--primary-color); color: var(--primary-color);">@InfoMessage</div>
    }

    <div class="card">
        <div class="card-header">Buyer Signature</div>
        <div style="background-color: var(--gray-50); padding: 1.5rem; border-radius: 4px;">
            @if (Contract.BuyerSign)
            {
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <p style="margin: 0; color: var(--gray-700); font-size: 0.9rem;">Signed By</p>
                        <p style="margin: 0.25rem 0; font-weight: 600;">Buyer workflow user</p>
                    </div>
                    <div>
                        <p style="margin: 0; color: var(--gray-700); font-size: 0.9rem;">Signed At</p>
                        <p style="margin: 0.25rem 0; font-weight: 600;">@Contract.BuyerSignAt?.ToLocalTime().ToString("g")</p>
                    </div>
                </div>
            }
            else
            {
                <p style="margin: 0; color: var(--gray-700);">The buyer has not signed this contract yet.</p>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">Your Signature</div>
        <div style="background-color: var(--gray-50); padding: 1.5rem; border-radius: 4px; margin-bottom: 1rem;">
            <p style="margin: 0; color: var(--gray-700);">By signing below, you agree to the terms and conditions of this contract.</p>
        </div>

        <div class="form-group" style="margin-bottom: 1rem;">
            <label class="form-label">Vendor Note</label>
            <textarea class="form-control" rows="3" @bind="VendorNote"></textarea>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
            <button type="button" class="btn btn-primary btn-lg" @onclick="HandleSign" disabled="@(!CanVendorAct || IsSubmitting)">@(IsSubmitting ? "Submitting..." : "Sign Contract")</button>
            <button type="button" class="btn btn-danger btn-lg" @onclick="HandleDecline" disabled="@(!CanVendorAct || IsSubmitting)">Decline Contract</button>
        </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
        <a href="@($"/vendor/dashboard?companyId={CompanyId}")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
}

@code {
    [Parameter]
    public int ContractId { get; set; }

    [SupplyParameterFromQuery]
    public int? CompanyIdQuery { get; set; }

    private bool IsLoading = true;
    private bool IsSubmitting;
    private string? ErrorMessage;
    private string? InfoMessage;
    private int CompanyId = 1;
    private string CompanyIdInput = "1";
    private string? VendorNote;
    private VendorContractDetailResponse? Contract;

    private bool CanVendorAct => Contract is not null
        && Contract.BuyerSign
        && !Contract.VendorSign
        && Contract.Status != (int)RfpContractStatus.Declined
        && Contract.Status != (int)RfpContractStatus.Signed;

    protected override async Task OnInitializedAsync()
    {
        if (CompanyIdQuery is > 0)
        {
            CompanyId = CompanyIdQuery.Value;
            CompanyIdInput = CompanyId.ToString();
        }

        await LoadAsync();
    }

    private async Task ApplyCompanyAsync()
    {
        if (!int.TryParse(CompanyIdInput, out var parsedCompanyId) || parsedCompanyId <= 0)
        {
            ErrorMessage = "Enter a valid vendor company id before loading the contract.";
            return;
        }

        CompanyId = parsedCompanyId;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            Contract = await VendorApi.GetContractAsync(ContractId, CompanyId);
        }
        catch (ApiException ex)
        {
            ErrorMessage = ex.Error.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error while loading the contract: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleSign()
    {
        if (Contract is null)
        {
            return;
        }

        IsSubmitting = true;
        ErrorMessage = null;
        InfoMessage = null;

        try
        {
            await VendorApi.SignContractAsync(Contract.Id, new VendorActionRequest(CompanyId, VendorNote));
            VendorNote = null;
            InfoMessage = "Vendor signature recorded successfully.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            ErrorMessage = ex.Error.Code switch
            {
                "VENDOR_ALREADY_SIGNED" => "The vendor signature is already recorded for this contract.",
                "CONTRACT_ALREADY_DECLINED" => "The contract has already been declined and can no longer be signed.",
                _ => ex.Error.Message
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error while signing the contract: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task HandleDecline()
    {
        if (Contract is null)
        {
            return;
        }

        IsSubmitting = true;
        ErrorMessage = null;
        InfoMessage = null;

        try
        {
            await VendorApi.DeclineContractAsync(Contract.Id, new VendorActionRequest(CompanyId, VendorNote));
            InfoMessage = "Contract decline recorded successfully.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            ErrorMessage = ex.Error.Code switch
            {
                "VENDOR_ALREADY_SIGNED" => "The vendor already signed this contract and can no longer decline it.",
                "CONTRACT_ALREADY_SIGNED" => "This contract is already fully signed.",
                _ => ex.Error.Message
            };
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error while declining the contract: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private static string ToContractStatusLabel(int status)
        => ((RfpContractStatus)status).ToString();
}
