@page "/buyer/rfps/create"
@using ProcureFlow.Web.Components.Shared

<PageTitle Title="Create RFP" Subtitle="Define items, specs, and invite vendors" />

<div class="card" style="max-width: 800px;">
    <form>
        <div class="form-group">
            <label class="form-label">RFP Title</label>
            <input type="text" class="form-control" placeholder="e.g., IT Equipment Supply Q2 2026" />
        </div>

        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="4" placeholder="Provide detailed requirements and context"></textarea>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-control">
                    <option>Select a category</option>
                    <option>Technology</option>
                    <option>Facilities</option>
                    <option>Services</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Budget Range</label>
                <input type="text" class="form-control" placeholder="e.g., $10,000 - $50,000" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Submission Deadline</label>
            <input type="datetime-local" class="form-control" />
        </div>

        <div class="form-group">
            <label class="form-label">Attachments</label>
            <input type="file" class="form-control" multiple />
        </div>

        <h3 style="margin-top: 2rem; margin-bottom: 1rem;">Items & Specs</h3>
        <div class="card" style="margin-bottom: 1rem; background-color: var(--gray-50);">
            <div style="padding: 1rem;">
                <p style="margin: 0; color: var(--gray-700);">
                    (Item/Spec input form will be built here - allows nested inputs)
                </p>
            </div>
        </div>

        <div style="display: flex; gap: 1rem;">
            <button type="submit" class="btn btn-primary btn-lg">Create RFP</button>
            <a href="/buyer/rfps" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </form>
</div>

@code {
    private async Task HandleSubmit()
    {
        // TODO: Post form to /api/buyer/rfps endpoint
        await Task.CompletedTask;
    }
}
